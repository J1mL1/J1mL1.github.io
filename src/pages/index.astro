---
import Layout from '../layouts/Layout.astro';
import NeumorphicCard from '../components/NeumorphicCard.astro';
import '../styles/main.css';

const pageTitle = "Zirui Li's Personal Space"
---

<Layout title={pageTitle}>
    <div class="layout-stack layout-stack--lg">
        <NeumorphicCard class="mb-8">
            <h1 class="page-heading text-center">Welcome to <span class="text-gradient">Zirui's Corner</span></h1>
            <p class="page-subheading text-center">
                Hello! I'm <strong>Zirui Li</strong>, you can call me <strong>Jim</strong>. I'm a computer science PhD student passionate about Natural Language Processing, especially in multimodal LLM research, machenism interpretability, and LLM reasoning. This is where I document my projects, life insights, and photographic works 📝
            </p>
        </NeumorphicCard>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <NeumorphicCard class="neu-hover-inset-sm transition-all duration-200">
                <a href="/blog" class="block link-plain">
                    <h2 class="card-title">Tech Blog <span class="card-arrow">→</span></h2>
                    <p class="card-description">Sharing programming experience, study notes and technical insights</p>
                </a>
            </NeumorphicCard>

            <NeumorphicCard class="neu-hover-inset-sm transition-all duration-200">
                <a href="/plog" class="block link-plain">
                    <h2 class="card-title">Photography Journal <span class="card-arrow">→</span></h2>
                    <p class="card-description">Capturing life moments, sharing photography collections 📸</p>
                </a>
            </NeumorphicCard>

            <NeumorphicCard class="neu-hover-inset-sm transition-all duration-200">
                <a href="/projects" class="block link-plain">
                    <h2 class="card-title">Project Showcase <span class="card-arrow">→</span></h2>
                    <p class="card-description">Documenting interesting projects I've participated in</p>
                </a>
            </NeumorphicCard>

            <NeumorphicCard class="neu-hover-inset-sm transition-all duration-200">
                <a href="/about" class="block link-plain">
                    <h2 class="card-title">About Me <span class="card-arrow">→</span></h2>
                    <p class="card-description">Learn more about my story and experiences</p>
                </a>
            </NeumorphicCard>

            <NeumorphicCard class="neu-hover-inset-sm transition-all duration-200">
                <a href="/contact" class="block link-plain">
                    <h2 class="card-title">Contact Me <span class="card-arrow">→</span></h2>
                    <p class="card-description">Feel free to reach out with any questions or ideas 👋</p>
                </a>
            </NeumorphicCard>
        </div>
    </div>
</Layout>
