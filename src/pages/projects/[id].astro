---
import Layout from '../../layouts/Layout.astro';
import NeumorphicCard from '../../components/NeumorphicCard.astro';
import '../../styles/main.css';
import { getCollection, type CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

const thumbnailModules = import.meta.glob('../../content/projects/**/*.{png,jpg,jpeg,webp,avif,gif}', {
  eager: true,
  import: 'default'
}) as Record<string, ImageMetadata>;

const resolveThumbnail = (thumbnail: ImageMetadata | string | undefined): ImageMetadata | undefined => {
  if (!thumbnail) return undefined;
  if (typeof thumbnail !== 'string') return thumbnail;
  const key = `../../content/projects/${thumbnail.replace(/^\.\//, '')}`;
  return thumbnailModules[key];
};

export async function getStaticPaths() {
  const projectEntries = await getCollection('projects');
  return projectEntries.map((entry: CollectionEntry<'projects'>) => ({
    params: { id: entry.data.id },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<'projects'>;
};

const { entry } = Astro.props;
const { Content } = await entry.render();
const bannerImage = resolveThumbnail(entry.data.thumbnail);
const pageTitle = `${entry.data.title} | Project by Zirui Li`;
const pageDescription = entry.data.description;
const pageKeywords = entry.data.tags;
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
  <NeumorphicCard class="project-detail-card">
  <div class="project-detail-container">
    <div class="project-header">
            <a href="/projects" class="back-link">        &larr; Back to Projects      </a>
      <h1 class="page-title">{entry.data.title}</h1>
      {entry.data.links && entry.data.links.length > 0 && (
        <div class="project-links project-links--detail" aria-label={`${entry.data.title} resource links`}>
          {entry.data.links.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener"
              aria-label={`Visit ${link.label}`}
            >
              <img src={link.badge} alt={`${link.label} badge`} loading="lazy" decoding="async" />
            </a>
          ))}
        </div>
      )}
      <div class="project-meta">
        <div class="project-tags">
          {entry.data.tags.map((tag: string) => (
            <span class="project-tag">{tag}</span>
          ))}
        </div>
        <div class="project-date">{entry.data.date}</div>
      </div>
    </div>

    <div class="project-banner">
      {bannerImage ? (
        <Image
          src={bannerImage}
          alt={entry.data.title}
          class="project-banner-image"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <img
          src="/images/placeholder.svg"
          alt={`${entry.data.title} placeholder`}
          class="project-banner-image"
          loading="lazy"
          decoding="async"
        />
      )}
      <div class="project-loading">
        <div class="spinner"></div>
      </div>
    </div>

    <article class="markdown-content">
      <Content />
    </article>
  </div>
  </NeumorphicCard>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll<HTMLImageElement>('.project-banner-image');
    images.forEach(img => {
      const container = img.closest('.project-banner');
      const loadingDiv = container?.querySelector('.project-loading');

      const markLoaded = () => {
        img.classList.add('loaded');
        if (loadingDiv) (loadingDiv as HTMLElement).style.opacity = '0';
      };

      if (img.complete) {
        if (img.naturalWidth === 0) {
          img.removeAttribute('srcset');
          img.src = '/images/placeholder.svg';
        }
        markLoaded();
      } else {
        img.addEventListener('load', markLoaded, { once: true });
        img.addEventListener('error', () => {
          img.removeAttribute('srcset');
          container?.querySelectorAll('source').forEach(el => el.remove());
          img.src = '/images/placeholder.svg';
          markLoaded();
        }, { once: true });
      }
    });
  });
</script> 
