---
import Layout from "../layouts/Layout.astro";
import "../styles/main.css";

const siteOrigin = Astro.site ? Astro.site.origin : "https://j1ml1.github.io";
const homeUrl = `${siteOrigin.replace(/\/$/, "")}/`;
---

<Layout
    title="About — moved"
    description="This profile now lives on the home page."
    canonical={homeUrl}
    noIndex={true}
    robots="noindex, follow"
>
    <div class="layout-stack" style="text-align: center; padding: 2rem 1rem;">
        <p class="item-text">
            This profile is now on the <a class="inline-link" href="/">home page</a>.
        </p>
        <script is:inline>
            window.location.replace("/");
        </script>
    </div>
</Layout>
