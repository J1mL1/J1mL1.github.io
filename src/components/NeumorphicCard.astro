---
export interface Props {
	class?: string;
	elevated?: boolean;
	pressed?: boolean;
	padding?: string;
}

const {
	class: className = '',
	elevated = true,
	pressed = false,
	padding = 'p-6',
	...rest
} = Astro.props;

const shadowClass = pressed 
	? 'shadow-neu-inset-md'
	: elevated
	? 'shadow-neu-md'
	: 'shadow-neu-sm';
---

<div
	class:list={[
		'neu-surface',
		'rounded-xl',
		'transition-all',
		'duration-300',
		padding,
		shadowClass,
		className,
	]}
	{...rest}
>
	<slot />
</div>
