---
export interface Props extends astroHTML.JSX.LiHTMLAttributes<HTMLLIElement> {
	title: string;
	body: string;
	href: string;
}

const {
	href,
	title,
	body,
	class: className = '',
	target,
	rel,
	...rest
} = Astro.props;

const externalRel = target === '_blank' ? rel ?? 'noopener noreferrer' : rel;
---

<li class:list={['link-card', className]} {...rest}>
	<a
		href={href}
		class="link-plain"
		target={target}
		rel={externalRel}
	>
		<slot name="title">
			<h2>
				{title}
				<span aria-hidden="true">&rarr;</span>
			</h2>
		</slot>
		<slot>
			<p>{body}</p>
		</slot>
	</a>
</li>
