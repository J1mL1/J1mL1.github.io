---
export interface Props extends astroHTML.JSX.InputHTMLAttributes<HTMLInputElement> {
	class?: string;
	variant?: 'inset' | 'raised';
}

const {
	class: className = '',
	variant = 'inset',
	type = 'text',
	...rest
} = Astro.props;

const classList = [
	'neu-surface',
	'rounded-xl',
	'px-4',
	'py-3',
	'transition-all',
	'duration-200',
	'focus:outline-none',
	'w-full',
	className,
	variant === 'inset' ? 'shadow-neu-inset-sm' : 'shadow-neu-sm',
	variant === 'inset' ? 'focus:shadow-neu-inset-md' : 'focus:shadow-neu-md',
];
---

<input
	type={type}
	class:list={classList}
	{...rest}
/>
