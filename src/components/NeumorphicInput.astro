---
export interface Props {
	class?: string;
	type?: string;
	placeholder?: string;
	name?: string;
	id?: string;
	value?: string;
	required?: boolean;
}

const { 
	class: className = '', 
	type = 'text', 
	placeholder = '', 
	name = '',
	id = '',
	value = '',
	required = false
} = Astro.props;

const baseClasses = `bg-neu-base rounded-xl px-4 py-3 transition-all duration-200 shadow-neu-inset-sm focus:shadow-neu-inset-md focus:outline-none w-full ${className}`;
---

<input 
	type={type}
	class={baseClasses}
	placeholder={placeholder}
	name={name}
	id={id}
	value={value}
	required={required}
/>

<style>
	:global(.bg-neu-base) {
		background-color: var(--neu-base);
	}
	
	:global(input::placeholder) {
		color: rgba(0, 0, 0, 0.5);
	}
	
	:global(.dark input::placeholder) {
		color: rgba(255, 255, 255, 0.5);
	}
</style>

